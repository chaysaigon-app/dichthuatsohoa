rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    // Safe role: trả về '' nếu user doc chưa tồn tại (user mới đăng ký)
    function userRole() {
      let snap = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return snap.data.get('role', '');
    }
    function isSuperAdmin() {
      return isSignedIn() && userRole() == 'superadmin';
    }
    function isAdmin() {
      return isSignedIn() && userRole() in ['admin', 'superadmin'];
    }
    function isStaff() {
      return isSignedIn() && userRole() in ['staff', 'admin', 'superadmin'];
    }
    function isCustomer() {
      return isSignedIn() && userRole() == 'customer';
    }
    // Cho phép user mới (chưa có doc) hoặc customer
    function isCustomerOrNew() {
      return isSignedIn() && (userRole() == 'customer' || userRole() == '');
    }

    // ─── users ──────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isStaff());

      allow create: if isSignedIn() && (
        (request.auth.uid == uid && request.resource.data.get('role','customer') == 'customer')
        || isAdmin()
      );

      allow update: if isAdmin()
        || (isSignedIn() && request.auth.uid == uid
            && !('role' in request.resource.data.diff(resource.data).affectedKeys()));

      allow delete: if isSuperAdmin();
    }

    // ─── orders ─────────────────────────────────────────────────────
    match /orders/{id} {
      // LIST query (where customerUid==uid): chỉ cần đăng nhập — query tự filter
      // GET đơn lẻ: phải là staff hoặc chính chủ
      allow list: if request.auth != null;
      allow get:  if isStaff()
        || (request.auth != null && (
              resource.data.customerUid == request.auth.uid
           || resource.data.customerEmail == request.auth.token.email
           || resource.data.email == request.auth.token.email
           ));
      allow create: if request.auth != null;
      allow update: if isStaff()
        || (request.auth != null
            && resource.data.customerUid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['customerRating','customerComment','updatedAt']));
      allow delete: if isSuperAdmin();
    }

    // ─── leads ──────────────────────────────────────────────────────
    match /leads/{id} {
      allow create: if isSignedIn();
      allow read, update: if isStaff();
      allow delete: if isAdmin();
    }

    // ─── invoices ───────────────────────────────────────────────────
    match /invoices/{id} {
      allow read: if isStaff()
        || (isCustomerOrNew() && (
              resource.data.customerUid == request.auth.uid
           || resource.data.customerEmail == request.auth.token.email
           ));
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // ─── activity ───────────────────────────────────────────────────
    match /activity/{id} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isSuperAdmin();
    }

    // ─── quotes (inbound – từ website/portal khách gửi) ─────────────
    match /quotes/{id} {
      allow create: if true;
      allow list:   if request.auth != null;
      allow get:    if isStaff() || (request.auth != null && resource.data.customerUid == request.auth.uid);
      allow update, delete: if isStaff();
    }

    // ─── staff_quotes (báo giá nội bộ – do nhân viên lập) ───────────
    match /staff_quotes/{id} {
      allow list:   if request.auth != null;
      allow get:    if isStaff() || (request.auth != null && resource.data.customerUid == request.auth.uid);
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // ─── customer_quotes (báo giá gửi lên portal khách) ─────────────
    match /customer_quotes/{id} {
      allow list:   if request.auth != null;
      allow get:    if isStaff() || (request.auth != null && resource.data.customerUid == request.auth.uid);
      allow create: if isStaff();
      allow update: if isStaff()
        || (request.auth != null
            && resource.data.customerUid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['status','confirmedAt','rejectedAt','rejectReason','orderId','orderNum','updatedAt']));
      allow delete: if isAdmin();
    }

    // ─── contacts ───────────────────────────────────────────────────
    match /contacts/{id} {
      allow create: if true;
      allow read, update, delete: if isStaff();
    }

    // ─── reviews ────────────────────────────────────────────────────
    match /reviews/{id} {
      allow read: if true;
      allow create: if isCustomerOrNew();
      allow update, delete: if isAdmin();
    }

    // ─── notifications ──────────────────────────────────────────────
    match /notifications/{id} {
      // Staff can read all admin notifications; customers read their own
      allow read: if isSignedIn()
        && (isStaff()
            || resource.data.recipientUid == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && (isStaff() || resource.data.recipientUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ─── settings (staffStatus online toggle) ────────────────────────
    match /settings/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    // ─── conversations + messages ────────────────────────────────────
    match /conversations/{convId} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;

      match /messages/{msgId} {
        allow read:           if true;
        allow create:         if true;
        allow update, delete: if isStaff();
      }
    }

  }
}
