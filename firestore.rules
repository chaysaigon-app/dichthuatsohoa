rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────
    function isSignedIn() { return request.auth != null; }
    function role() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role; }
    function isSuperAdmin() { return isSignedIn() && role() == 'superadmin'; }
    function isAdmin()      { return isSignedIn() && (role() == 'admin' || role() == 'superadmin'); }
    function isStaff()      { return isSignedIn() && (role() == 'staff' || role() == 'admin' || role() == 'superadmin'); }
    function isCustomer()   { return isSignedIn() && role() == 'customer'; }

    // ── orders ───────────────────────────────────────────────
    match /orders/{id} {
      allow read: if isStaff() || (isCustomer() &&
        (resource.data.customerUid == request.auth.uid ||
         resource.data.customerEmail == request.auth.token.email));
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isSuperAdmin();
    }

    // ── leads ────────────────────────────────────────────────
    match /leads/{id} {
      allow read, write: if isStaff();
      allow delete: if isAdmin();
    }

    // ── invoices ─────────────────────────────────────────────
    match /invoices/{id} {
      allow read: if isStaff() || (isCustomer() &&
        (resource.data.customerUid == request.auth.uid ||
         resource.data.customerEmail == request.auth.token.email));
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // ── users ────────────────────────────────────────────────
    match /users/{uid} {
      // Ai cũng đọc được profile của chính mình
      allow read: if isSignedIn() && (request.auth.uid == uid || isStaff());
      // Chỉ superadmin/admin mới tạo/sửa/xóa tài khoản nhân viên
      allow create: if isAdmin();
      allow update: if isAdmin() || request.auth.uid == uid;
      allow delete: if isSuperAdmin();
    }

    // ── activity log ─────────────────────────────────────────
    match /activity/{id} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isSuperAdmin();
    }

    // ── contacts (form liên hệ từ website — public write) ────
    match /contacts/{id} {
      allow create: if true;
      allow read, update, delete: if isStaff();
    }

    // ── reviews (đánh giá từ portal KH) ─────────────────────
    match /reviews/{id} {
      allow read: if true;
      allow create: if isCustomer();
      allow update, delete: if isAdmin();
    }

    // ── notifications ────────────────────────────────────────
    match /notifications/{id} {
      allow read: if isSignedIn() && (resource.data.toUid == request.auth.uid || isStaff());
      allow create: if isStaff();
      allow update: if isSignedIn() && resource.data.toUid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── conversations (chat widget từ website) ───────────────
    // conversations/{convId}
    match /conversations/{convId} {
      // Khách: đọc/ghi conversation của mình qua convId lưu localStorage
      // Staff/Admin: đọc/ghi tất cả
      allow read: if isStaff() || true; // public read để khách load lịch sử
      allow create: if true;            // public create để khách bắt đầu chat
      allow update: if isStaff() || true; // khách cập nhật guestPhone

      // messages subcollection
      match /messages/{msgId} {
        allow read: if true;
        allow create: if true;  // khách và staff đều gửi được
        allow update, delete: if isStaff();
      }
    }
  }
}
