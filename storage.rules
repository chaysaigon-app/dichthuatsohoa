rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Quote files — khách upload khi gửi yêu cầu báo giá
    match /quote-files/{uid}/{fileName} {
      // Chỉ user đó mới upload được vào folder của mình
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 15 * 1024 * 1024;
      // Admin và chính user đó đều đọc được
      allow read: if request.auth != null;
    }

    // Order result files — nhân viên upload tài liệu hoàn thành
    match /order-results/{orderId}/{fileName} {
      allow write: if request.auth != null;
      allow read:  if request.auth != null;
    }

  }
}
